{
	"common": {
		// <Display> Displays the hex inside readonly casting items; working client-side
		"RevealsHexInsideCastingItems": false,
		// <Mote> Enables item IO without casting patterns
		"EnablesMoteItemHandler": true,
		/* <Mote> Enables 'A Glance of Mote Chest' (a simple chest GUI) on right click
		   disables if `EnablesMoteItemHandler` is off
		*/
		"EnablesMoteChestGUI": true,
		// <Misc> Player references are always valid even in another dimension
		"TrueNameCrossDimension": true,
		// <Mishap> Mishaps won't drop items anymore
		"EnablesMishapNoYeet": true,
		/* <Mishap> (DEPRECATED after HexCasting 0.11.3 because there's no limit anymore)
		   Teleporting riding entities no longer do mishaps
		*/
		"EnablesTeleportVehicles": true,
		// <Pattern> if not, the `YJSP's Charge Media` pattern will be disabled
		"EnablesChargeMediaAction": false,
		// <Pattern> if not, mind environment series patterns will be disabled
		"EnablesMindEnvActions": true,
		/* <Pattern> level 1 enables extra `setHealth` method call;
		   level 2 adds saved data searching & replacing if lv.1 failed
		*/
		"TrulyHurtLevel": 2,
		// <Pattern.FactorCut> if not, Factor Cut pattern will be disabled
		"EnablesFactorCutSpell": true,
		// <Pattern.FactorCut> const cost for prime factors (in 1e-4 dust)
		"FactorCutPrimeCost": 10000,
		// <Pattern.FactorCut> const cost for non-prime factors (multiplied by the factor itself, in 1e-4 dust)
		"FactorCutNonPrimeCostScale": 50000,
		// <Pattern.FactorCut> cost for the fallback hurt-1 action (in 1e-4 dust)
		"FactorCutFallbackCost": 50001,
		// <Pattern.FactorCut> target's health gets extra random reduction after each successful division
		"FactorCutRandomMode": false,
		// <Pattern.FactorCut> minimum factor usable for division; factors less than this (if not equal to target health) will be denied
		"FactorCutMinimumFactor": 2,
		// <Pattern.FactorCut> entities with health under hou many points can be wiped for free
		"FactorCutKillingBlowLine": 1,
		// <Personal Media> Enables player's personal media pool
		"EnablesPersonalMediaPool": false,
		// <Personal Media> Max media (in 0.0001 dust) for personal pool
		"PersonalMediaMax": 1000000,
		// <Personal Media> How many media points (in 0.0001 dust) personal pool regenerates each time
		"PersonalMediaRegenStep": 50000,
		// <Personal Media> For every X ticks personal pool regenerate once
		"PersonalMediaRegenInterval": 20,
		// <Personal Media> Fake players (for example, Deployer from Create) won't regenerate their media pool
		"FakePlayerDontRegenMedia": true,
		// <Personal Media> Only activates personal media bar after enlightened
		"PersonalMediaAfterEnlightened": false,
		// <Personal Media> Triggers events when personal media pool changed
		"FiresPersonalMediaEvents": true,
		// <Amethyst Circle> media waves from circles go through amethyst budding blocks, and accelerates their crystal growth
		"EnablesAmethystCircle": true,
		// <Amethyst Circle> each time media reduces for crystal growth passing a budding block
		"AmethystCircleSingleChargeCost": 100000,
		// <Amethyst Circle> max possible charging level of the wave: growth strength = min(this, wave total media / single cost)
		"AmethystCircleFullPowerLevel": 15,
		// <Property> making property iotas directly execute what's inside when themselves executed
		"ExecutablePropertyIota": true,
		// <HexParse> Makes artifacts directly read/writeable via HexParse methods; requires restart for changes to apply.
		"EnablesArtifactIO": true
	}
}